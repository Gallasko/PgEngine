{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-c",
                    "mingw32-make DEBUG=True PROD=True -j 8"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "make DEBUG=True PROD=True"
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    "-c",
                    "Z:/Cmake/bin/cmake.EXE --build x:/Document/GitHub/TeclaEatsDesktop/build --config Debug --target all -j 22 --"
                ]
            },
            "problemMatcher": []
        },
        {
            "label": "test",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-c",
                    "mingw32-make test DEBUG=True PROD=True -j 8",
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "make DEBUG=True PROD=True"
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    "-c",
                    "make DEBUG=True PROD=True"
                ]
            },
            "problemMatcher": []
        },
        {
            "label": "release",
            "type": "shell",
            "group": {
                "kind": "release",
                "isDefault": false
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-c",
                    "Z:/Cmake/bin/cmake.EXE --build x:/Document/GitHub/TeclaEatsDesktop/release --config Release --target PgEngine -j 22 --"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "make DEBUG=False"
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    "-c",
                    "make DEBUG=False"
                ]
            },
            "problemMatcher": []
        },
        {
            "label": "build & run",
            "type": "shell",
            "windows": {
                "command": "powershell",
                "args": [
                    "-c",
                    "'mingw32-make run'"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "'make run'"
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    "-c",
                    "'make run'"
                ]
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "windows": {
                "command": "powershell",
                "args": [
                    "-c",
                    "'mingw32-make clean'"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "'make clean'"
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    "-c",
                    "'make clean'"
                ]
            }
        }
    ]
}